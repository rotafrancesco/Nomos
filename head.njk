<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}{% if title != "Nomos" %} — Nomos{% endif %}</title>
<meta name="description" content="{{ description }}">

<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png">
<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">

<meta property="og:type" content="{{ ogType | default('website') }}">
<meta property="og:title" content="{{ title }}{% if title != \'Nomos\' %} — Nomos{% endif %}">
<meta property="og:description" content="{{ description }}">
<meta property="og:image" content="/og-image.png">
<meta property="og:locale" content="en_GB">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}{% if title != \'Nomos\' %} — Nomos{% endif %}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="/og-image.png">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --paper: #FFFFFF;
    --paper-deep: #F3F2EE;
    --ink: #12182A;
    --ink-soft: #2B3550;
    --slate: #5B6478;
    --rule: #B8AF98;
    --rule-soft: #CFC8B4;
    --oxblood: #7A2A2A;
    --max: 1120px;
  }

  *{ box-sizing: border-box; }
  html{ -webkit-text-size-adjust: 100%; }

  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:'Source Serif 4', Georgia, serif;
    line-height:1.6;
  }

  a{ color:inherit; text-decoration:none; }
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--oxblood);
    outline-offset:3px;
  }

  @media (prefers-reduced-motion: reduce){
    *{ transition:none !important; animation:none !important; }
  }

  .wrap{
    max-width:var(--max);
    margin:0 auto;
    padding:0 28px;
  }

  /* ---------- Top meta bar ---------- */
  .topbar{
    border-bottom:1px solid var(--rule);
  }
  .topbar .wrap{
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:6px;
    padding-top:14px;
    padding-bottom:14px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--slate);
  }
  .topbar span{ white-space:nowrap; }

  /* ---------- Masthead ---------- */
  .masthead{
    padding:44px 0 0;
    text-align:center;
  }
  .masthead .kicker{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    letter-spacing:0.32em;
    text-transform:uppercase;
    color:var(--oxblood);
    margin:0 0 18px;
  }
  .masthead h1{
    font-family:'Fraunces', serif;
    font-weight:700;
    font-size:clamp(3.2rem, 9vw, 6rem);
    letter-spacing:-0.01em;
    margin:0;
    color:var(--ink);
  }
  .masthead h1 em{
    font-style:italic;
    font-weight:500;
    color:var(--ink-soft);
  }
  .masthead .tagline{
    font-family:'Source Serif 4', serif;
    font-style:italic;
    font-size:1.05rem;
    color:var(--ink-soft);
    margin:12px 0 0;
  }

  /* Survey-line signature divider: a boundary line with tick marks,
     standing in for the founding "division of land" the word nomos names */
  .survey-line{
    display:block;
    width:100%;
    height:22px;
    margin:26px 0 0;
  }
  .survey-line line, .survey-line path{
    stroke:var(--ink-soft);
    stroke-width:1;
  }

  /* ---------- Nav ---------- */
  nav.primary{
    border-top:1px solid var(--rule);
    border-bottom:3px double var(--ink-soft);
    background:var(--paper);
  }
  nav.primary .wrap{
    display:flex;
    justify-content:center;
    gap:36px;
    padding:14px 28px;
    flex-wrap:wrap;
  }
  nav.primary a{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.76rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--ink);
    padding-bottom:4px;
    border-bottom:1px solid transparent;
    transition:border-color 0.15s ease, color 0.15s ease;
  }
  nav.primary a:hover{
    border-bottom-color:var(--oxblood);
    color:var(--oxblood);
  }

  /* ---------- Layout grid ---------- */
  main{ padding:52px 0 0; }
  .layout{
    display:grid;
    grid-template-columns: 2.1fr 1fr;
    gap:56px;
    align-items:start;
  }
  @media (max-width: 860px){
    .layout{ grid-template-columns: 1fr; gap:44px; }
  }

  /* ---------- Lead feature ---------- */
  .tag{
    display:inline-block;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--oxblood);
    border:1px solid var(--oxblood);
    padding:3px 9px;
    margin-bottom:16px;
  }
  .lead h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(1.9rem, 4vw, 2.7rem);
    line-height:1.12;
    margin:0 0 14px;
  }
  .lead .dek{
    font-style:italic;
    color:var(--ink-soft);
    font-size:1.12rem;
    margin:0 0 18px;
    max-width:52ch;
  }
  .byline{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--slate);
    margin-bottom:26px;
    padding-bottom:22px;
    border-bottom:1px solid var(--rule-soft);
  }
  .lead .body p{
    font-size:1.06rem;
    margin:0 0 20px;
  }
  .lead .body p:first-of-type::first-letter{
    font-family:'Fraunces', serif;
    font-weight:700;
    font-size:4.6rem;
    line-height:0.78;
    float:left;
    padding:6px 10px 0 0;
    color:var(--oxblood);
  }
  .note{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.72rem;
    color:var(--slate);
    border-left:2px solid var(--rule);
    padding-left:12px;
    margin-top:30px;
  }

  /* ---------- Essay teaser (homepage) ---------- */
  .essay-teaser{
    max-width:74ch;
    padding:36px 0 8px;
  }
  .essay-teaser h2{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:clamp(1.7rem, 3.6vw, 2.3rem);
    line-height:1.16;
    margin:0 0 12px;
  }
  .essay-teaser h2 a{
    border-bottom:1px solid transparent;
    transition:color 0.15s ease, border-color 0.15s ease;
  }
  .essay-teaser h2 a:hover{
    color:var(--oxblood);
    border-bottom-color:var(--oxblood);
  }
  .essay-teaser .dek{
    font-style:italic;
    color:var(--ink-soft);
    font-size:1.05rem;
    margin:0 0 14px;
  }
  .read-more{
    display:inline-block;
    margin-top:6px;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.74rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--oxblood);
    border-bottom:1px solid var(--oxblood);
    padding-bottom:2px;
  }
  .read-more:hover{ opacity:0.75; }

  /* ---------- Full essay ---------- */
  .essay-full{
    max-width:74ch;
    margin:0 auto;
  }
  .essay-full .dek{ max-width:none; }
  .essay-full .body h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-style:italic;
    font-size:1.4rem;
    color:var(--ink-soft);
    margin:40px 0 16px;
  }
  .essay-full blockquote{
    margin:32px 0;
    padding:20px 26px;
    background:var(--paper-deep);
    border-left:3px solid var(--oxblood);
    font-style:italic;
    font-size:1.05rem;
    color:var(--ink-soft);
  }
  .essay-full blockquote p:last-child{
    display:block;
    margin-top:10px;
    margin-bottom:0;
    font-family:'IBM Plex Mono', monospace;
    font-style:normal;
    font-size:0.72rem;
    letter-spacing:0.06em;
    text-transform:uppercase;
    color:var(--slate);
  }
  .essay-full .body ul{
    list-style:none;
    margin:32px 0 0;
    padding:24px 0 0;
    border-top:1px solid var(--rule-soft);
    font-family:'IBM Plex Mono', monospace;
    font-size:0.8rem;
    color:var(--slate);
    line-height:1.7;
  }
  .essay-full .body li{
    padding-left:1.6em;
    text-indent:-1.6em;
    margin-bottom:10px;
  }

  /* ---------- Sidebar ---------- */
  aside{
    border-left:1px solid var(--rule);
    padding-left:36px;
  }
  @media (max-width: 860px){
    aside{ border-left:none; border-top:1px solid var(--rule); padding-left:0; padding-top:36px; }
  }
  aside h3{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.74rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--ink);
    margin:0 0 20px;
    padding-bottom:10px;
    border-bottom:1px solid var(--rule-soft);
  }
  .brief-item{
    padding:16px 0;
    border-bottom:1px solid var(--rule-soft);
  }
  .brief-item:last-child{ border-bottom:none; }
  .brief-item .cat{
    display:block;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.66rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--oxblood);
    margin-bottom:6px;
  }
  .brief-item h4{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.08rem;
    margin:0 0 6px;
    line-height:1.3;
  }
  .brief-item p{
    font-size:0.9rem;
    color:var(--ink-soft);
    margin:0;
  }

  /* ---------- Section: forthcoming briefs ---------- */
  .section-head{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    border-top:3px double var(--ink-soft);
    border-bottom:1px solid var(--rule);
    padding:34px 0 12px;
    margin-top:56px;
  }
  .section-head h3{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.5rem;
    margin:0;
  }
  .section-head span{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    color:var(--slate);
    letter-spacing:0.08em;
    text-transform:uppercase;
  }

  .cards{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:32px;
    padding:32px 0 12px;
  }
  @media (max-width: 860px){
    .cards{ grid-template-columns:1fr; }
  }
  .card{
    background:var(--paper-deep);
    padding:26px 22px;
    border-top:3px solid var(--ink-soft);
  }
  .card .cat{
    display:block;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.66rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--oxblood);
    margin-bottom:10px;
  }
  .card h4{
    font-family:'Fraunces', serif;
    font-weight:600;
    font-size:1.18rem;
    margin:0 0 10px;
    line-height:1.28;
  }
  .card p{
    font-size:0.92rem;
    color:var(--ink-soft);
    margin:0;
  }

  /* ---------- Colophon / footer ---------- */
  footer{
    margin-top:70px;
    border-top:3px double var(--ink-soft);
    background:var(--ink);
    color:var(--paper);
  }
  footer .wrap{
    padding:44px 28px 34px;
    display:grid;
    grid-template-columns:1.4fr 1fr;
    gap:44px;
  }
  @media (max-width: 860px){
    footer .wrap{ grid-template-columns:1fr; }
  }
  footer h3{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:#B9AE8F;
    margin:0 0 14px;
  }
  footer p{
    font-size:0.94rem;
    color:#CFCABB;
    margin:0 0 14px;
    max-width:60ch;
  }
  footer .colophon-word{
    font-family:'Fraunces', serif;
    font-style:italic;
    color:var(--paper);
  }
  .subscribe{
    display:flex;
    gap:0;
    max-width:360px;
    margin-top:6px;
  }
  .subscribe input{
    flex:1;
    background:transparent;
    border:1px solid #55607C;
    border-right:none;
    padding:10px 12px;
    color:var(--paper);
    font-family:'Source Serif 4', serif;
    font-size:0.9rem;
  }
  .subscribe input::placeholder{ color:#8A93AC; }
  .subscribe button{
    background:var(--oxblood);
    border:1px solid var(--oxblood);
    color:var(--paper);
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    padding:0 18px;
    cursor:pointer;
  }
  .fine{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.68rem;
    color:#8A93AC;
    border-top:1px solid #333E5C;
    padding:18px 28px;
    display:flex;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:8px;
  }

  /* ---------- Essay page (standalone) ---------- */
  .essay-page-header{
    border-bottom:1px solid var(--rule);
    padding:20px 0;
  }
  .back-link{
    font-family:'IBM Plex Mono', monospace;
    font-size:0.74rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--ink);
    border-bottom:1px solid transparent;
  }
  .back-link:hover{ border-bottom-color:var(--oxblood); color:var(--oxblood); }
  .essay-page-main{ padding:48px 0 70px; }
  .essay-footer{
    margin-top:70px;
    border-top:3px double var(--ink-soft);
    background:var(--ink);
    color:#CFCABB;
    padding:28px 0;
    font-family:'IBM Plex Mono', monospace;
    font-size:0.7rem;
    text-align:center;
  }
</style>

</head>
